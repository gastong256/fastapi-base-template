# ── Application ──────────────────────────────────────────────────────────────
APP_APP_NAME=__PROJECT_NAME__
APP_DESCRIPTION=__DESCRIPTION__

# local | test | prod
APP_ENVIRONMENT=local

# Set true for colorized console logs; false for structured JSON (production default)
APP_DEBUG=true
APP_LOG_LEVEL=INFO

# ── Server ────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_MODULE=__PROJECT_SLUG__.main:app
APP_WEB_CONCURRENCY=1
APP_KEEPALIVE_TIMEOUT=5
APP_BACKLOG=2048
APP_LIMIT_CONCURRENCY=0
APP_PROXY_HEADERS=false
APP_FORWARDED_ALLOW_IPS=127.0.0.1
APP_METRICS_ENABLED=true
APP_METRICS_PATH=/metrics

# Comma-separated values (leave empty to disable)
APP_CORS_ORIGINS=

# Comma-separated values. Use "*" only in local development.
APP_ALLOWED_HOSTS=*
APP_TRUST_X_FORWARDED_FOR=false

# ── OpenTelemetry (optional) ──────────────────────────────────────────────────
# Requires: poetry install --with otel
APP_OTEL_ENABLED=false
APP_OTEL_ENDPOINT=http://localhost:4317
APP_OTEL_SERVICE_NAME=__SERVICE_NAME__

# ── Database ───────────────────────────────────────────────────────────────────
# Default local sqlite for zero-setup development.
# PostgreSQL example:
# APP_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/app
APP_DATABASE_URL=sqlite+aiosqlite:///./app.db
APP_DATABASE_ECHO=false
APP_DATABASE_POOL_SIZE=10
APP_DATABASE_MAX_OVERFLOW=20
APP_DATABASE_POOL_TIMEOUT=30
APP_DATABASE_POOL_RECYCLE=1800
APP_DATABASE_CONNECT_ON_STARTUP=false
APP_DATABASE_AUTO_CREATE_SCHEMA=true

# ── Authentication / Authorization ────────────────────────────────────────────
# Enable in prod. Keep false locally unless testing JWT flows.
APP_AUTH_ENABLED=false
APP_AUTH_JWT_SECRET=change-me-please-use-a-long-random-secret
APP_AUTH_JWT_ALGORITHM=HS256
APP_AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30
APP_AUTH_ISSUER=__SERVICE_NAME__
APP_AUTH_AUDIENCE=__SERVICE_NAME__-clients
APP_AUTH_ADMIN_USERNAME=admin
APP_AUTH_ADMIN_PASSWORD=change-me
APP_AUTH_ADMIN_SCOPES=items:read,items:write

# ── Rate Limiting ──────────────────────────────────────────────────────────────
APP_RATE_LIMIT_ENABLED=true
APP_RATE_LIMIT_BACKEND=memory
APP_RATE_LIMIT_REQUESTS=120
APP_RATE_LIMIT_WINDOW_SECONDS=60
APP_RATE_LIMIT_FAIL_OPEN=true
APP_RATE_LIMIT_REDIS_URL=redis://localhost:6379/0
APP_RATE_LIMIT_REDIS_PREFIX=__SERVICE_NAME__
APP_RATE_LIMIT_EXEMPT_PATHS=/health,/ready,/api/docs,/api/redoc,/api/openapi.json

# ── Security Headers ───────────────────────────────────────────────────────────
APP_SECURITY_HEADERS_ENABLED=true
APP_SECURITY_CSP=default-src 'self'; frame-ancestors 'none'; base-uri 'self'
APP_SECURITY_HSTS_ENABLED=false
APP_SECURITY_HSTS_SECONDS=31536000
